global_defs {
    enable_script_security
}

vrrp_script chk_web {
    script "/usr/local/bin/check_web.sh"
    interval 2
    timeout 2
    weight -30
    rise 1
    fall 2
}

vrrp_instance VI_1 {
    state {{ keepalived_state }}
    interface {{ net_if }}
    virtual_router_id 51
    priority {{ keepalived_priority }}
    advert_int 1
    virtual_ipaddress {
        192.168.200.200
    }
    track_script {
        chk_web
    }
}
